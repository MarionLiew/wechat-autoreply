# ── 大模型配置 ──────────────────────────────────────────────
# provider 可选：anthropic / openai / moonshot / zhipu / qwen / custom
LLM_PROVIDER=anthropic

# API Key（anthropic 填 sk-ant-xxx，其他 provider 填对应 key）
LLM_API_KEY=

# 是否启用大模型回复（即使配置了 Key 也可单独关闭）
LLM_ENABLED=false

# 模型名（为空时按 provider 使用默认值）
# anthropic 默认: claude-haiku-4-5
# openai 默认:    gpt-4o-mini
# moonshot 默认:  moonshot-v1-8k
# zhipu 默认:     glm-4-flash
# qwen 默认:      qwen-turbo
LLM_MODEL=

# 自定义 base URL（仅 provider=custom 时需要填写）
LLM_BASE_URL=

# AI 系统提示词（描述你的业务场景）
SYSTEM_PROMPT=你是一位专业的客服助手，请用简洁、礼貌的中文回复客户问题。

# ── 废话库 ──────────────────────────────────────────────────
# 无规则命中时是否从废话库随机抽取一条回复（fillers.json 中配置废话）
FILLER_ENABLED=false

# ── 回复延迟（随机扰动，模拟人工回复节奏） ─────────────────
REPLY_DELAY_MIN_SECONDS=1.0
REPLY_DELAY_MAX_SECONDS=5.0

# ── 存储 ────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./messages.db
LOG_LEVEL=INFO

# ── Mac Watcher 配置 ─────────────────────────────────────────
# 轮询间隔（秒）：检查企业微信未读消息的频率
POLL_INTERVAL_SECONDS=5
# 企业微信 Mac 应用 Bundle ID（通常无需修改）
# 查询方式：osascript -e 'id of app "企业微信"'
WECOM_BUNDLE_ID=com.tencent.WeWorkMac
