# Claude AI（https://console.anthropic.com/）
CLAUDE_API_KEY=sk-ant-XXXXXXXXXX
CLAUDE_MODEL=claude-haiku-4-5

# AI 系统提示词（描述你的业务场景）
SYSTEM_PROMPT=你是一位专业的客服助手，请用简洁、礼貌的中文回复客户问题。

# 存储
DATABASE_URL=sqlite:///./messages.db
LOG_LEVEL=INFO

# Mac Watcher 配置
# 轮询间隔（秒）：检查企业微信未读消息的频率
POLL_INTERVAL_SECONDS=5
# 企业微信 Mac 应用 Bundle ID（通常无需修改）
# 查询方式：osascript -e 'id of app "企业微信"'
WECOM_BUNDLE_ID=com.tencent.WeWorkMac
