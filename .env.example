# 企业微信凭证
# 我的企业 → 企业信息 → 企业ID
CORP_ID=wwXXXXXXXXXXXXXXXX

# 自建应用 → 应用管理 → 应用Secret
CORP_SECRET=your_corp_secret_here

# 回调配置（自定义，填入企业微信后台时保持一致）
TOKEN=your_callback_token_here
ENCODING_AES_KEY=your_43_char_base64_key_here

# 自建应用 AgentID
AGENT_ID=1000001

# 微信客服账号ID（客户联系 → 微信客服 → 客服账号，以 wk 开头）
OPEN_KF_ID=wkXXXXXXXXXXXXXX

# Claude AI（https://console.anthropic.com/）
CLAUDE_API_KEY=sk-ant-XXXXXXXXXX
CLAUDE_MODEL=claude-haiku-4-5

# AI 系统提示词（描述你的业务场景）
SYSTEM_PROMPT=你是一位专业的客服助手，请用简洁、礼貌的中文回复客户问题。

# 存储
DATABASE_URL=sqlite:///./messages.db
LOG_LEVEL=INFO
